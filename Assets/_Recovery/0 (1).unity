  hitMessages:
  - "TRAFI\u0141E\u015A!"
  - TRAFIONY!
  - JEST!
  - BAM!
  - CELNIE!
  - TRAFIONY!
  - "DOSTA\u0141!"
  - "OBERWA\u0141!"
  - PAC!
  - "GI\u0143!"
  rareMessageChance: 0.001
  rareHitMessages:
  - "Czysto teoretycznie, za\u0142\xF3\u017Cmy, za\u0142\xF3\u017Cmy czysto teoretycznie,
    \u017Ce jeste\u015B prezydentem \u017B\xF3\u0142clandii. \u017B\xF3\u0142clandia
    zajmuje powiedzmy 30% naszego globu. Twoja \u017B\xF3\u0142clandia jest mocarstwem,
    nuklearnym, atomowym, jakimkolwiek. Jest bardzo pot\u0119\u017Cna militarnie
    i w og\xF3le, prawda? I w pewnym momencie przylatuje Ci jaki\u015B przedstawiciel
    cholera, \u015Aluzlandii drugiej planety \u015Aluzlandii i m\xF3wi ci tak! S\u0142uchaj...
    ziomie z \u017B\xF3\u0142clandii, albo si\u0119 dogadujemy i przylatuje do ciebie
    co tydzie\u0144 i przygotowywujesz mi tutaj 10 m\u0119\u017Cczyzn, 10 kobiet,
    to, tam, tam, toto, albo wracam na m\xF3j statek i odpalam cholera moje mi\u0119dzygalaktyczne
    dzia\u0142o w twoj\u0105 nieszcz\u0119sn\u0105 planet\u0119. Co by\u015B zrobi\u0142,
    co by\u015B zrobi\u0142... w takim przypadku?"
